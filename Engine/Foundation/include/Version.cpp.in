/**
    @file version.cpp.in
    @brief CMake에 사용되는 템플릿
*/
#include "version.h"


namespace fd
{
    SVersionNumber GetVersionNumber() noexcept
    {
        return { @LIB_MAJOR_VERSION@, @LIB_MINOR_VERSION@, @LIB_PATCH_VERSION@ };
    }

    std::string_view GetVersionNumberStr() noexcept
    {
        return { "@LIB_VERSION_STRING@" };
    }

    SVersionInfo GetVersionInfo() noexcept
    {
        return { "@LIB_VERSION_NAME@", "@LIB_FEATURES_INFO@", GetVersionNumber() };
    }
}
